# NaruMa — Mako notifications (Cyberpunk)

sort=-time
layer=overlay
anchor=top-right

background-color=#0d0d1a
text-color=#e0e0ff
border-color=#16213e
border-radius=0
border-size=2

width=360
height=150
margin=10
padding=12

font=JetBrainsMono Nerd Font 11
max-icon-size=32
icon-path=/usr/share/icons/Papirus-Dark

default-timeout=5000
ignore-timeout=0

[urgency=low]
border-color=#16213e
default-timeout=3000

[urgency=normal]
border-color=#00f5ff

[urgency=high]
border-color=#ff0055
text-color=#ff0055
default-timeout=0
