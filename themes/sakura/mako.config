# NaruMa — Mako notifications (Sakura)

sort=-time
layer=overlay
anchor=top-right

background-color=#1a0e1e
text-color=#f2d4e0
border-color=#3d2b44
border-radius=0
border-size=2

width=360
height=150
margin=10
padding=12

font=JetBrainsMono Nerd Font 11
max-icon-size=32
icon-path=/usr/share/icons/Papirus-Dark

default-timeout=5000
ignore-timeout=0

[urgency=low]
border-color=#3d2b44
default-timeout=3000

[urgency=normal]
border-color=#3d2b44

[urgency=high]
border-color=#ef9a9a
text-color=#ef9a9a
default-timeout=0
