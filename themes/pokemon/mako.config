# NaruMa — Mako notifications (Pokémon)

sort=-time
layer=overlay
anchor=top-right

background-color=#1a1a2e
text-color=#e8f0f5
border-color=#2e3860
border-radius=0
border-size=2

width=360
height=150
margin=10
padding=12

font=JetBrainsMono Nerd Font 11
max-icon-size=32
icon-path=/usr/share/icons/Papirus-Dark

default-timeout=5000
ignore-timeout=0

[urgency=low]
border-color=#2e3860
default-timeout=3000

[urgency=normal]
border-color=#f7d51d

[urgency=high]
border-color=#ef5350
text-color=#ef5350
default-timeout=0
